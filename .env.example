# API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# InfoJobs API Credentials
INFOJOBS_CLIENT_ID=your_client_id
INFOJOBS_CLIENT_SECRET=your_client_secret
INFOJOBS_OAUTH_TOKEN=your_oauth_token

# Job Application Controls
DRY_RUN=true
JOB_KEYWORDS=Desarrollador,Programador,React,Node,Python,TypeScript
JOB_LOCATIONS=Peru,Lima,Remoto
MIN_SALARY=0
RUN_INTERVAL_HOURS=12

# Slack/Discord Webhooks (Optional for notifications while traveling)
NOTIFICATION_WEBHOOK_URL=
